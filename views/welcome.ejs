<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0;
            min-height: 100vh;
            font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(160deg, #e8f3ff, #f7faff 56%, #ffffff);
            color: #0f172a;
        }

        .header {
            background: #0067c5;
            color: white;
            padding: 20px 28px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 8px 18px rgba(0, 0, 0, 0.2);
        }

        .header .brand {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .header .brand img {
            height: 26px;
        }

        .header .brand h1 {
            margin: 0;
            font-size: 24px;
            font-weight: 700;
        }

        .header a {
            color: #f1f5f9;
            text-decoration: none;
            font-weight: 700;
            border: 1px solid rgba(255, 255, 255, 0.45);
            padding: 8px 14px;
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.1);
        }

        .header a:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        .main {
            max-width: 1080px;
            margin: 24px auto;
            padding: 0 20px;
        }

        .hero {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 24px;
        }

        .hero .card {
            border-radius: 14px;
            background: white;
            border: 1px solid #dbeafe;
            padding: 18px;
            box-shadow: 0 8px 18px rgba(15, 23, 42, 0.08);
        }

        .hero .card h2 {
            margin: 0 0 10px;
            font-size: 20px;
            color: #0f172a;
        }

        .hero .card p {
            margin: 0;
            color: #475569;
            line-height: 1.42;
        }

        .features {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 16px;
        }

        .feature-item {
            display: flex;
            gap: 14px;
            align-items: flex-start;
            padding: 12px;
            border-radius: 12px;
            background: #ffffff;
            border: 1px solid #e2e8f0;
            box-shadow: 0 3px 10px rgba(15, 23, 42, 0.06);
        }

        .feature-item img {
            width: 48px;
            height: 48px;
            border-radius: 8px;
            object-fit: cover;
        }

        .feature-item .text {
            font-size: 15px;
            color: #0f172a;
            font-weight: 600;
        }
    </style>
</head>

<body>
    <div class="header">
        <div class="brand">
            <h1>Demo Dashboard</h1>
        </div>
        <h4 align="center">By Dr. Chikkanna T G</h4>
        <a href="/logout">Logout</a>
    </div>

    <main class="main">
        <div class="hero">
            <div class="card">
                <h2>Welcome, <%= username %>
                </h2>
                <p>You're logged in successfully. Below are the top level load & performance testing tools.</p>
            </div>
        </div>

        <section>
            <h2 style="margin: 0 0 14px; font-size: 22px; color: #1e3a8a;">List of Load & Performance Testing Tools</h2>
            <div class="features">
                <% ptTools.forEach(feature=> { %>
                    <div class="feature-item">
                        <div class="text">
                            <%= feature %>
                        </div>
                    </div>
                    <% }) %>
            </div>
        </section>
    </main>
</body>

</html>